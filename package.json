{
  "name": "hive-plugin",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:schema": "vitest run tests/schema",
    "test:agents": "vitest run tests/agents",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run test:coverage"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.7.0"
  }
}

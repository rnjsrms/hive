{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "title", "type", "risk", "status", "convoy", "description", "acceptance_criteria", "dependencies", "history", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^wi-\\d+$" },
    "title": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["feature", "bugfix", "refactor", "test", "docs", "research"] },
    "risk": { "type": "string", "enum": ["low", "medium", "high"] },
    "status": { "type": "string", "enum": ["open", "assigned", "in-progress", "review", "approved", "changes-requested", "testing", "tests-failed", "ready-to-merge", "blocked", "merged", "cancelled"] },
    "assignee": { "type": ["string", "null"] },
    "convoy": { "type": "string", "pattern": "^convoy-\\d+$" },
    "branch": { "type": ["string", "null"] },
    "description": { "type": "string" },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "history": { "type": "array", "items": {
      "type": "object",
      "required": ["action", "agent", "ts"],
      "properties": {
        "action": { "type": "string" },
        "agent": { "type": "string" },
        "ts": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    }},
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "title", "type", "risk", "status", "feature", "description", "acceptance_criteria", "dependencies", "history", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9]+-\\d+_WI-\\d+$" },
    "title": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["feature", "bugfix", "refactor", "test", "docs", "research"] },
    "risk": { "type": "string", "enum": ["low", "medium", "high"] },
    "status": { "type": "string", "enum": ["OPEN", "ASSIGNED", "IN_PROGRESS", "REVIEW", "APPROVED", "CHANGES_REQUESTED", "TESTING", "TESTS_FAILED", "READY_TO_MERGE", "BLOCKED", "MERGED", "CANCELLED"] },
    "assignee": { "type": ["string", "null"] },
    "feature": { "type": "string", "pattern": "^[A-Z][A-Z0-9]+-\\d+$" },
    "branch": { "type": ["string", "null"] },
    "description": { "type": "string" },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "history": { "type": "array", "items": {
      "type": "object",
      "required": ["action", "agent", "ts"],
      "properties": {
        "action": { "type": "string" },
        "agent": { "type": "string" },
        "ts": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }},
    "tags": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" } },
    "reviewers": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" } },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}

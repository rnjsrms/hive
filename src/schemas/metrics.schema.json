{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["autoresearch_status"],
  "properties": {
    "autoresearch_status": { "type": "string", "enum": ["idle", "running"] },
    "autoresearch_started_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
    "consecutive_reverts": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}

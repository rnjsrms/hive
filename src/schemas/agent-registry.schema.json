{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["agents"],
  "properties": {
    "agents": { "type": "array", "items": {
      "type": "object",
      "required": ["id", "role", "status", "current_work_item", "sprint_id", "last_heartbeat"],
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["developer", "reviewer", "tester", "researcher", "monitor"] },
        "status": { "type": "string", "enum": ["ACTIVE", "IDLE", "BLOCKED", "COMPLETED", "STOPPED", "DEAD"] },
        "current_work_item": { "type": ["string", "null"] },
        "sprint_id": { "type": "string" },
        "last_heartbeat": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] }
      },
      "additionalProperties": false
    }}
  },
  "additionalProperties": false
}
